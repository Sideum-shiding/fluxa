import fluxaui

func main() -> Void:
    fluxaui.title("Full Fluxa Example")
    fluxaui.text("This program uses main-first execution, FluxaUI, and cin().")

    fluxaui.section("Input")
    let name: String = cin({Your name})
    let age: Int = cin({Your age})
    let likes_fluxa: Bool = cin({Do you like Fluxa? true/false})

    fluxaui.section("Result")
    fluxaui.field("Name", name)
    fluxaui.field("Age", age)
    fluxaui.field("Likes Fluxa", likes_fluxa)
    fluxaui.success("Done")
