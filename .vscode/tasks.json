{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Fluxa: Run Current File",
      "type": "shell",
      "command": "${workspaceFolder}\\fluxa.exe",
      "args": [
        "run",
        "${file}"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": {
        "owner": "fluxa",
        "fileLocation": [
          "absolute"
        ],
        "pattern": [
          {
            "regexp": "^(.*):(\\d+): error (FLX\\d+): (.*)$",
            "file": 1,
            "line": 2,
            "code": 3,
            "message": 4
          }
        ]
      }
    }
  ]
}
